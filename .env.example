# TEMM1E Environment Variables
# Copy this to .env and fill in your value:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)

# Telegram Bot Token (required) — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Exa API Key (optional) — enables AI-powered web search tool
# Get your key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=your-exa-api-key-here
